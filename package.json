{
  "name": "unity-store-downloader",
  "version": "1.0.0",
  "description": "Bulk downloader for Unity Asset Store purchased assets via kharma API",
  "type": "module",
  "scripts": {
    "download": "tsx src/index.ts",
    "dry-run": "tsx src/index.ts --dry-run",
    "extract": "tsx src/extract.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/sharp": "^0.31.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "unity",
    "asset-store",
    "downloader",
    "unitypackage"
  ],
  "license": "MIT",
  "dependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "fbx2gltf": "^0.9.7-p1",
    "obj2gltf": "^3.2.0",
    "sharp": "^0.34.5"
  }
}
